DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DIM=768
# e5 models expect asymmetric instruction prefixes. Leave EMPTY for MiniLM.
EMBEDDING_QUERY_PREFIX=query:
EMBEDDING_PASSAGE_PREFIX=passage:
# L2-normalize embeddings (required for cosine distance search). Keep true.
EMBEDDING_NORMALIZE=true

# ── Retrieval ────────────────────────────────────────────────────────────────
TOP_K=5

LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
LLM_MAX_TOKENS=4096
# Adaptive extended thinking for the extraction step (slower, sometimes better).
LLM_THINKING=false

# ── Ingestion ────────────────────────────────────────────────────────────────
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_HIGHLIGHTS_DIR=data/highlights
# A page with fewer than this many extractable characters counts as "no text".
# If most pages have no text, the document is treated as scanned and OCR'd.
SCANNED_CHAR_THRESHOLD=100
SCANNED_PAGE_RATIO=0.5
# Tesseract language packs to use for OCR (install the matching packs).
OCR_LANGUAGES=ron+eng
# Optional: transcribe/describe pages OCR can't read (diagrams, photos) with a
# Claude vision call — makes them searchable. Requires ANTHROPIC_API_KEY; costs tokens.
OCR_VISION_FALLBACK=false
# Chunking strategy: "page" (v1: 1 page = 1 chunk) or "window" (fixed char windows).
CHUNK_STRATEGY=page
CHUNK_WINDOW_SIZE=1200
CHUNK_WINDOW_OVERLAP=150
# On re-ingesting an already-seen file (same content hash): "skip" or "replace".
INGEST_ON_DUPLICATE=skip

# Also render an annotated PDF/PNG per answer span using PyMuPDF.
HIGHLIGHT_PDF=true

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
