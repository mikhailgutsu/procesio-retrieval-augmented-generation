DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DIM=768
EMBEDDING_QUERY_PREFIX=query:
EMBEDDING_PASSAGE_PREFIX=passage:
EMBEDDING_NORMALIZE=true

# ── Retrieval ────────────────────────────────────────────────────────────────
TOP_K=5
# Hybrid search fuses vector similarity with Postgres full-text (keyword) search,
# so exact rare terms (brand names like "GENEREX") are found even when semantic
# similarity is weak. Results are merged with Reciprocal Rank Fusion.
RETRIEVAL_HYBRID=true
RETRIEVAL_CANDIDATE_K=40
RETRIEVAL_RRF_K=60
# Drop vector-only hits below this cosine score (keyword hits are always kept).
# 0 = disabled. e5 scores are compressed, so keep this low; the LLM grounding
# (answerable=false) is the primary "not found" guard.
RETRIEVAL_MIN_SCORE=0.70

# Answer-extraction provider: "openai" (ChatGPT) or "anthropic" (Claude).
LLM_PROVIDER=openai
VISION_PROVIDER=
# ── OpenAI / ChatGPT ──────────────────────────────────────────────────────────
# Paste your ChatGPT API key here (starts with "sk-"). Get one at
# https://platform.openai.com/api-keys . Used by /ask when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# ── Anthropic / Claude (alternative provider) ─────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
LLM_MAX_TOKENS=4096
LLM_THINKING=false

# ── CORS (frontend access) ────────────────────────────────────────────────────
# Comma-separated allowed origins for the browser frontend; "*" for the POC.
CORS_ALLOW_ORIGINS=*

# ── Ingestion ────────────────────────────────────────────────────────────────
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_HIGHLIGHTS_DIR=data/highlights
SCANNED_CHAR_THRESHOLD=100
SCANNED_PAGE_RATIO=0.5
OCR_LANGUAGES=ron+eng
# Use the LLM vision model to read images/diagrams/photos (and OCR-poor PDF
# pages). Needed to capture text that tesseract misses — e.g. brand names on
# equipment photos. For standalone images vision always runs when this is on.
OCR_VISION_FALLBACK=true
CHUNK_STRATEGY=page
CHUNK_WINDOW_SIZE=1200
CHUNK_WINDOW_OVERLAP=150
# "replace" re-ingests a file even if already present (use when re-processing
# images with vision); "skip" ignores duplicates.
INGEST_ON_DUPLICATE=replace

# Also render an annotated PDF/PNG per answer span using PyMuPDF.
HIGHLIGHT_PDF=true

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
